{
  "application": {
    "systemName": "Aether OS",
    "version": "1.0.0-bootstrap",
    "environment": "development",
    "configVersion": "1.0.0"
  },
  "logging": {
    "level": "INFO",
    "format": "structured",
    "includeTimestamp": true
  },
  "runtime": {
    "maxEventQueueSize": 1000,
    "tickRate": 10,
    "maxLoadedModules": 10
  },
  "development": {
    "debugMode": true,
    "mockHardware": true,
    "hmrDisabled": true
  },
  "ai": {
    "modelName": "gemini-2.5-flash",
    "maxTokens": 2048,
    "temperature": 0.7
  },
  "memory": {
    "vectorDim": 1536,
    "persistInterval": 300
  },
  "communication": {
    "port": 3000,
    "protocol": "http"
  }
}
